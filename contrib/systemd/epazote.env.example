# ---------------------------------------------------------------------------
# epazote packaged service environment
# ---------------------------------------------------------------------------

# Primary config file used by the systemd unit.
EPAZOTE_CONFIG=/etc/epazote/epazote.yml

# Metrics bind port for the packaged service.
EPAZOTE_PORT=9080

# Logging verbosity for the packaged service.
# Valid examples: 0, 1, 2, 3
EPAZOTE_VERBOSE=

# Set to 1/true/yes to emit structured JSON logs.
# Leave empty or set to 0/false/no for pretty logs.
# EPAZOTE_JSON_LOGS=0

# Optional OpenTelemetry export settings.
# Leave these unset for the lightest runtime footprint.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer example-token
# OTEL_SDK_DISABLED=true

# The active config is intentionally not packaged here because watchdog checks
# and fallback commands are environment-specific. Provision
# /etc/epazote/epazote.yml with your configuration management before starting
# the service.
